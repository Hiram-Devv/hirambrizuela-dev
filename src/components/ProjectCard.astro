---
import type { Project } from "../lib/projects";
import { Icon } from "astro-icon/components";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { name, description, stack, links, featured } = project;
---

<article
  class="group py-6 border-b border-border last:border-b-0 grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-3 sm:gap-6"
>
  <div>
    <div class="flex items-baseline gap-3 mb-2 flex-wrap">
      <h3 class="text-lg font-medium tracking-tight">{name}</h3>
      {
        featured && (
          <span class="text-[11px] text-accent border border-accent/30 rounded px-1.5 py-0.5">
            Destacado
          </span>
        )
      }
    </div>

    <p class="text-sm text-muted leading-relaxed mb-3">
      {description}
    </p>

    <div class="flex flex-wrap gap-1.5">
  {
    stack.map((tech) => (
      <span class="inline-flex items-center gap-1.5 text-[11px] bg-surface text-ink/80 px-2 py-1 rounded">
        {tech.icon && <Icon name={tech.icon} class="size-3" />}
        {tech.name}
      </span>
    ))
  }
</div>
  </div>

  <div class="flex sm:flex-col gap-3 sm:gap-2 text-xs sm:items-end">
    {
      links.demo && (
        <a
          href={links.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:underline whitespace-nowrap"
        >
          Demo ↗
        </a>
      )
    }
    {
      links.repo && (
        <a
        
          href={links.repo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:underline whitespace-nowrap"
        >
          Código ↗
        </a>
      )
    }
  </div>
</article>