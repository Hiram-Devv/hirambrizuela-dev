---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Section from "../components/Section.astro";
import ProjectCard from "../components/ProjectCard.astro";
import {projects} from "../lib/projects";
import {stack} from "../lib/stack";
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";


---

<BaseLayout title="Hiram Brizuela · Software Engineer">
	<Header />

	<main >
		<section class="mx-auto max-w-3xl px-6 pt-20 pb-24 sm:pt-32 sm:pb-32">
			<p class="text-sm text-muted mb-4">Software Engineer</p>

      <h1 class="font-serif text-5xl sm:text-6xl leading-[1.05] tracking-tight mb-8">
        Hola, soy <em class="text-accent not-italic">Hiram</em>.<br />
        Construyo interfaces<br />
        rápidas y mantenibles.
      </h1>

      <p class="text-lg text-muted leading-relaxed max-w-xl">
        Egresado de Ingeniería en Software por la Universidad de Colima y
        certificado por AWS. Trabajo profesionalmente con React, Next.js y
        TypeScript.
      </p>
    </section>

	 <!-- Placeholder de secciones (las llenamos después) -->
    <Section id="sobre-mi" number="01" title="Sobre mí">
      <div class="space-y-5 text-base leading-relaxed">
    <p>
      Llegué al desarrollo por influencia de un familiar dev y por una
      fascinación temprana con la tecnología. Estudié Ingeniería en Software
      en la Universidad de Colima.
    </p>
    <p>
      Desde principios de 2025 trabajo profesionalmente en frontend 
	  (<a
      
        href="https://michelada.io"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:underline">Michelada.io</a
      >, ahora <span class="text-ink">MXMart</span>), construyendo interfaces
      con Next.js, TypeScript y stacks modernos. Soy de entendimiento visual:
      por eso me apasiona ver una interacción funcionando bien, una animación
      que se siente justa, una página que carga rápido.
    </p>
    <p>
      Mi próximo paso: expandirme hacia backend con NestJS y explorar IA.
      Fuera del código, soy fanático del fútbol.
    </p>
  </div>
    </Section>

    <Section id="proyectos" number="02" title="Proyectos">
     <div>
		{projects.map((project) => <ProjectCard project={project}/>)}
	 </div>
    </Section>

<Section id="stack" number="03" title="Stack">
  <div class="space-y-8">
    {
      stack.map((category) => (
        <div>
          <h3 class="text-sm text-muted mb-3 font-medium">{category.name}</h3>
          <div class="flex flex-wrap gap-2">
            {category.items.map((item) => (
              <span class="inline-flex items-center gap-2 text-sm bg-surface px-3 py-1.5 rounded-md">
                {item.icon && (
                  <Icon name={item.icon} class="size-3.5 text-ink/70" />
                )}
                {item.name}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</Section>

   <Section id="contacto" number="04" title="Contacto">
  <div>
    <h2 class="font-serif text-3xl sm:text-4xl tracking-tight mb-4">
      ¿Trabajamos juntos?
    </h2>

    <p class="text-muted leading-relaxed mb-8 max-w-md">
      Siempre abierto a conversar sobre proyectos interesantes, oportunidades
      laborales o simplemente intercambiar ideas.
    </p>

    <ul class="space-y-3 text-sm">
      <li class="flex gap-4">
        <span class="text-muted w-20 shrink-0">Email</span>
        <a
          href="mailto:hiramdev02@gmail.com"
          class="hover:text-accent transition-colors"
        >
          hiramdev02@gmail.com
        </a>
      </li>
      <li class="flex gap-4">
        <span class="text-muted w-20 shrink-0">GitHub</span>
        <a
        
          href="https://github.com/Hiram-Devv"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:underline"
        >
          github.com/Hiram-Devv ↗
        </a>
      </li>
      <li class="flex gap-4">
        <span class="text-muted w-20 shrink-0">LinkedIn</span>
        <a
        
          href="https://www.linkedin.com/in/hiram-avalos02"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:underline"
        >
          linkedin.com/in/hiram-avalos02 ↗
        </a>
      </li>
    </ul>
  </div>
</Section>
		
		
	</main>

	<Footer />

</BaseLayout>
