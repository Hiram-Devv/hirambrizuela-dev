---
interface Props {
  id: string;
  number: string;
  title: string;
}

const { id, number, title } = Astro.props;
---

<section id={id} class="border-t border-border">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-[140px_1fr] gap-6 sm:gap-10">
      <div>
        <p class="text-xs text-muted tracking-widest uppercase">
          {number} · {title}
        </p>
      </div>
      <div>
        <slot />
      </div>
    </div>
  </div>
</section>