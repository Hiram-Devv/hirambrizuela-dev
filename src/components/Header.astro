---
import ThemeToggle from "./ThemeToggle";


const navLinks = [
  { href: "#sobre-mi", label: "Sobre mí" },
  { href: "#proyectos", label: "Proyectos" },
  { href: "#stack", label: "Stack" },
  { href: "#contacto", label: "Contacto" },
];
---

<header class="sticky top-0 z-50 bg-bg/80 backdrop-blur-md border-b border-border">
    <div class="mx-auto max-w-3xl px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-sm font-medium tracking-tight">
            hiram<span class="text-accent">.dev</span>
        </a>

        <nav class="hidden sm:flex items-center gap-7 text-sm text-muted">
            {
                navLinks.map((link) => (
                    <a href={link.href} class="hover:text-ink transition-colors">
                        {link.label}
                    </a>
                ))
            }
        </nav>

        <ThemeToggle client:load/>
    </div>
</header>