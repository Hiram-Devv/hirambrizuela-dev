---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Section from "../../components/Section.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { Icon } from "astro-icon/components";
import { projects } from "../../lib/projects";
import { stack } from "../../lib/stack";
import { useTranslations } from "../../i18n/ui";

const lang = "en";
const t = useTranslations(lang);
---

<BaseLayout title={`Hiram Brizuela · ${t("hero.role")}`} lang={lang}>
  <Header lang={lang} />

  <main>
    <!-- Hero -->
    <section class="mx-auto max-w-3xl px-6 pt-20 pb-24 sm:pt-32 sm:pb-32">
      <p class="text-sm text-muted mb-4">{t("hero.role")}</p>

      <h1 class="font-serif text-5xl sm:text-6xl leading-[1.05] tracking-tight mb-8">
        {t("hero.greeting")} <em class="text-accent not-italic">Hiram</em>.<br />
        {t("hero.heading2")}<br />
        {t("hero.heading3")}
      </h1>

      <p class="text-lg text-muted leading-relaxed max-w-xl">
        {t("hero.subtitle")}
      </p>
    </section>

    <Section id="sobre-mi" number={t("about.number")} title={t("about.title")}>
      <div class="space-y-5 text-base leading-relaxed">
        <p>{t("about.p1")}</p>
        <p>
          {t("about.p2Before")}
          <a
            href="https://michelada.io"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent hover:underline">Michelada.io</a
          >{t("about.p2Middle")}<span class="text-ink">MXMart</span>{t("about.p2After")}
        </p>
        <p>{t("about.p3")}</p>
      </div>
    </Section>

    <Section id="proyectos" number={t("projects.number")} title={t("projects.title")}>
      <div>
        {projects.map((project) => <ProjectCard project={project} lang={lang} />)}
      </div>
    </Section>

    <Section id="stack" number={t("stack.number")} title={t("stack.title")}>
      <div class="space-y-8">
        {
          stack.map((category) => (
            <div>
              <h3 class="text-sm text-muted mb-3 font-medium">
                {t(`stack.categories.${category.key}`)}
              </h3>
              <div class="flex flex-wrap gap-2">
                {category.items.map((item) => (
                  <span class="inline-flex items-center gap-2 text-sm bg-surface px-3 py-1.5 rounded-md">
                    {item.icon && (
                      <Icon name={item.icon} class="size-3.5 text-ink/70" />
                    )}
                    {item.name}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </Section>

    <Section id="contacto" number={t("contact.number")} title={t("contact.title")}>
      <div>
        <h2 class="font-serif text-3xl sm:text-4xl tracking-tight mb-4">
          {t("contact.heading")}
        </h2>

        <p class="text-muted leading-relaxed mb-8 max-w-md">
          {t("contact.subtitle")}
        </p>

        <ul class="space-y-3 text-sm">
          <li class="flex gap-4">
            <span class="text-muted w-20 shrink-0">{t("contact.labels.email")}</span>
            <a href="mailto:hiramdev02@gmail.com" class="hover:text-accent transition-colors">
              hiramdev02@gmail.com
            </a>
          </li>
          <li class="flex gap-4">
            <span class="text-muted w-20 shrink-0">{t("contact.labels.github")}</span>
            <a
              href="https://github.com/Hiram-Devv"
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:underline"
            >
              github.com/Hiram-Devv ↗
            </a>
          </li>
          <li class="flex gap-4">
            <span class="text-muted w-20 shrink-0">{t("contact.labels.linkedin")}</span>
            <a
              href="https://www.linkedin.com/in/hiram-avalos02"
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:underline"
            >
              linkedin.com/in/hiram-avalos02 ↗
            </a>
          </li>
        </ul>
      </div>
    </Section>
  </main>

  <Footer lang={lang} />
</BaseLayout>